{
  "template_version": "v1",
  "project_name": "",
  "source_repo": "",
  "source_branch": "",
  "project_supercell_repo": "",
  "authority": {
    "source_repo_is_canonical_for": [
      "code",
      "project_local_primary_docs"
    ],
    "project_supercell_is_canonical_for": [
      "long_term_memory",
      "normalized_state",
      "resume_packets"
    ],
    "global_atticus_supercell_role": "umbrella_cross_project_continuity_root"
  },
  "required_files": [
    "README.md",
    "CURRENT_STATE/<project>_state.md",
    "MEMORY/cells/",
    "SESSION_PACKETS/generated/"
  ],
  "baseline": {
    "active_branch": "",
    "baseline_version": "",
    "active_packet": "",
    "notes": "Fill with normalized current project state before scaling out durable memory cells."
  },
  "starter_cells": [
    {
      "cell_type": "project_baseline",
      "required_fields": [
        "cell_id",
        "title",
        "content",
        "context_summary",
        "context_scope",
        "context_tags",
        "source_repo",
        "source_ref",
        "source_branch",
        "baseline_app_version",
        "baseline_framework_version",
        "parent_cell_id",
        "created_at",
        "provenance",
        "context_fingerprint"
      ]
    }
  ],
  "resume_packet_rule": "Keep restart packets compact, grounded in current state, and linked to durable milestone cells.",
  "exit_criteria": [
    "project can be resumed from the project-local supercell without full original chat replay",
    "authority boundaries are explicit",
    "project-local supercell remains compatible with the global ATTICUS model"
  ]
}
