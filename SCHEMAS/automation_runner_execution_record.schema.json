{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ATTICUS Automation Runner Execution Record",
  "type": "object",
  "required": [
    "record_version",
    "runner_run_id",
    "current_refresh_id",
    "resolved_inputs",
    "resolved_current_pointers",
    "planned_phases",
    "phase_results",
    "status",
    "notes"
  ],
  "properties": {
    "record_version": { "type": "string" },
    "runner_run_id": { "type": "string" },
    "current_refresh_id": { "type": "string" },
    "resolved_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "path"],
        "properties": {
          "role": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "resolved_current_pointers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pointer", "path"],
        "properties": {
          "pointer": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "planned_phases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "phase_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "status", "summary"],
        "properties": {
          "phase": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": ["planned", "pass", "warn", "fail"]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
